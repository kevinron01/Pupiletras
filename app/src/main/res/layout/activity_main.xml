<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_main"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="52sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Encuentra las palabras ocultas"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="52dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="14dp"
        android:padding="4dp">

        <Button
            android:id="@+id/btnLevel1"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Nivel 1 — Fácil · Animales"
            android:textSize="17sp"
            android:backgroundTint="@color/level1" />

        <TextView
            android:id="@+id/tvDesc1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="14dp"
        android:padding="4dp">

        <Button
            android:id="@+id/btnLevel2"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Nivel 2 — Medio · Frutas"
            android:textSize="17sp"
            android:backgroundTint="@color/level2" />

        <TextView
            android:id="@+id/tvDesc2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="4dp">

        <Button
            android:id="@+id/btnLevel3"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Nivel 3 — Difícil · Países"
            android:textSize="17sp"
            android:backgroundTint="@color/level3" />

        <TextView
            android:id="@+id/tvDesc3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingBottom="4dp" />
    </LinearLayout>

</LinearLayout>
